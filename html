<script>
(function () {
  try {
    var setCookie = function (name, value) {
      document.cookie = name + "=" + encodeURIComponent(value) + "; path=/; Secure; SameSite=Strict";
    };

    var getCookie = function (name) {
      var nameEQ = name + "=";
      var cookies = document.cookie ? document.cookie.split(";") : [];
      for (var i = 0; i < cookies.length; i++) {
        var cookie = cookies[i];
        while (cookie.charAt(0) === " ") cookie = cookie.substring(1, cookie.length);
        if (cookie.indexOf(nameEQ) === 0) return decodeURIComponent(cookie.substring(nameEQ.length, cookie.length));
      }
      return null;
    };

    // --- CONFIG FLAGS (set any combination to true) ---
    var SHOW_ON_IPHONE_ONLY   = true;
    var SHOW_ON_ANDROID_ONLY  = true;
    var SHOW_ON_MOBILE_ONLY   = true;
    var SHOW_ON_DESKTOP_ONLY  = true;
    var SHOW_ON_IPAD_ONLY     = true;
    var SHOW_ON_TABLET_ONLY   = true;

    // --- DETECTION ---
    var ua = navigator.userAgent || "";
    var isIPhone   = /iPhone/i.test(ua);
    var isIPad     = /iPad/i.test(ua) || (isIPhone && navigator.maxTouchPoints > 1); // newer iPadOS UA
    var isAndroid  = /Android/i.test(ua);
    var isTablet   = /iPad|Tablet/i.test(ua) || (isAndroid && !/Mobile/i.test(ua));
    var isMobileUA = /Mobi|Android|iPhone|iPod/i.test(ua) || isIPad;
    var isDesktop  = !isMobileUA;

    // --- RULES (support multiple true flags) ---
    var flagsEnabled = (
      SHOW_ON_IPHONE_ONLY ||
      SHOW_ON_IPAD_ONLY ||
      SHOW_ON_ANDROID_ONLY ||
      SHOW_ON_TABLET_ONLY ||
      SHOW_ON_MOBILE_ONLY ||
      SHOW_ON_DESKTOP_ONLY
    );

    var match =
      (SHOW_ON_IPHONE_ONLY  && isIPhone)  ||
      (SHOW_ON_IPAD_ONLY    && isIPad)    ||
      (SHOW_ON_ANDROID_ONLY && isAndroid) ||
      (SHOW_ON_TABLET_ONLY  && isTablet)  ||
      (SHOW_ON_MOBILE_ONLY  && isMobileUA)||
      (SHOW_ON_DESKTOP_ONLY && isDesktop);

    // If any flags are set, but none matched → exit
    if (flagsEnabled && !match) return;

    // Prevent duplicate modal
    if (document.getElementById("gtm-device-modal")) return;

    if (getCookie("tap_modal_dismissed") === "true") return;

    var init = function () {
      var container = document.querySelector("#wrap.TAPHomePage") || document.body;
      if (!container) return;

      // --- CSS ---
      var css = ""
        + "#gtm-device-overlay{position:fixed;top:0;left:0;right:0;bottom:0;"
        + "background:rgba(0,0,0,0.5);display:flex;align-items:flex-start;justify-content:center;"
        + "z-index:2147483647;overflow:auto;opacity:0;transition:opacity 0.4s ease;}"
        + "#gtm-device-overlay.show{opacity:1;}"
        + "#gtm-device-modal{background:#fff;width:90vw;max-width:520px;max-height:85vh;overflow:auto;"
        + "border-radius:6px;box-shadow:0 20px 50px rgba(0,0,0,0.2);position:relative;"
        + "opacity:0;transform:translateY(-60px);margin-left:auto;margin-right:auto;"
        + "transition:margin-top 0.4s ease, opacity 0.4s ease, transform 0.4s ease;"
        + "font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;}"
        + "#gtm-device-modal.show{opacity:1;transform:translateY(0);}"
        + "@media (max-width:767px){#gtm-device-modal.show{margin-top:10px;}}"
        + "@media (min-width:768px){#gtm-device-modal.show{margin-top:30px;}}"
        + ".modal-header{padding:15px;border-bottom:1px solid #e5e5e5;position:relative;}"
        + "#gtm-device-close{position:absolute;top:10px;right:10px;"
        + "display:inline-flex;align-items:center;justify-content:center;"
        + "width:32px;height:32px;padding:0;margin:0;border:0;background:transparent;"
        + "border-radius:999px;cursor:pointer;color:#8a8a8a;}"
        + "#gtm-device-close svg{width:16px;height:16px;}"
        + "#gtm-device-close:hover{background:rgba(0,0,0,0.05);color:#444;}"
        + "#gtm-device-close:active{transform:scale(0.96);}"
        + "#gtm-device-close:focus{outline:2px solid #2684ff;outline-offset:2px;}";

      var styleEl = document.createElement("style");
      styleEl.appendChild(document.createTextNode(css));
      document.head.appendChild(styleEl);

      // --- Overlay + Modal ---
      var overlay = document.createElement("div");
      overlay.id = "gtm-device-overlay";

      var modal = document.createElement("div");
      modal.id = "gtm-device-modal";
      modal.setAttribute("role", "dialog");
      modal.setAttribute("aria-modal", "true");

      // --- Header ---
      var header = document.createElement("div");
      header.className = "modal-header";

      var title = document.createElement("h4");
      title.className = "modal-title";
      title.appendChild(document.createTextNode("TAP is Temporarily Unavailable"));

      var closeBtn = document.createElement("button");
      closeBtn.id = "gtm-device-close";
      closeBtn.setAttribute("type", "button");
      closeBtn.setAttribute("aria-label", "Close");
      closeBtn.innerHTML =
        '<svg aria-hidden="true" width="16" height="16" viewBox="0 0 16 16" focusable="false">' +
        '  <path d="M3.2 3.2L12.8 12.8M12.8 3.2L3.2 12.8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>' +
        '</svg>';

      header.appendChild(title);
      header.appendChild(closeBtn);

      // --- Body ---
      var body = document.createElement("div");
      body.className = "modal-body";
      body.innerHTML =
        "<p>Purchasing a TAP card and adding fare to your card is temporarily unavailable. We are working to resolve this service. Please load fare at a TAP Vending Machine or at the farebox on the bus. <br><a href='https://www.taptogo.net/TAPLocator2' target='_blank'>Find a TVM</a></p><hr style='color:#d8d8d8; width:90%;' /><br><p>La compra de tarjetas TAP y la recarga de saldo en su tarjeta no están disponibles temporalmente. Estamos trabajando para restablecer este servicio. Por favor, recargue su saldo en una máquina expendedora TAP o en la urna de pago del autobús. <br><a href='https://www.taptogo.net/TAPLocator2?lang=es target='_blank'>Encuentre una máquina expendedora de billetes</a></p>";

      modal.appendChild(header);
      modal.appendChild(body);
      overlay.appendChild(modal);
      container.appendChild(overlay);

      // --- Close Handling ---
      var prevOverflow = document.documentElement.style.overflow;
      document.documentElement.style.overflow = "hidden";

      var closeModal = function () {
        setCookie("tap_modal_dismissed", "true");
        document.documentElement.style.overflow = prevOverflow || "";
        if (overlay && overlay.parentNode) overlay.parentNode.removeChild(overlay);
        if (styleEl && styleEl.parentNode) styleEl.parentNode.removeChild(styleEl);
      };

      closeBtn.addEventListener("click", closeModal, false);
      overlay.addEventListener("click", function (e) {
        if (e.target === overlay) closeModal();
      }, false);
      document.addEventListener("keydown", function (e) {
        if (e.key === "Escape" || e.keyCode === 27) closeModal();
      }, false);

      // --- Animate In ---
      setTimeout(function () {
        overlay.className += " show";
        modal.className += " show";
      }, 30);
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init, false);
    } else {
      init();
    }
  } catch (err) {
    if (window.console && console.warn) console.warn("[GTM Device Modal] error:", err);
  }
})();
</script>
